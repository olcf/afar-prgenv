#!/usr/bin/env bash
set -euo pipefail

wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

prepend_env_path() {
  local var="$1"
  local dir="$2"
  local val="${!var:-}"
  case ":${val}:" in
    *":${dir}:"*) return 0 ;;
  esac
  if [[ -n "${val}" ]]; then
    export "${var}=${dir}:${val}"
  else
    export "${var}=${dir}"
  fi
}

trim_line() {
  local line="$1"
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"
  printf '%s' "${line}"
}

UNSUPPORTED_PATTERNS=()
FILTER_ACTIONS=()
FILTER_PATTERNS=()
FILTER_REPLACEMENTS=()

load_unsupported_patterns() {
  local file="$1"
  [[ -f "${file}" ]] || return 0
  while IFS= read -r line || [[ -n "${line}" ]]; do
    line="${line%%#*}"
    line="$(trim_line "${line}")"
    [[ -z "${line}" ]] && continue
    UNSUPPORTED_PATTERNS+=("${line}")
  done < "${file}"
}

load_filter_rules() {
  local file="$1"
  [[ -f "${file}" ]] || return 0
  while IFS= read -r line || [[ -n "${line}" ]]; do
    line="${line%%#*}"
    line="$(trim_line "${line}")"
    [[ -z "${line}" ]] && continue
    local action="${line%% *}"
    local rest="${line#* }"
    [[ "${rest}" == "${line}" ]] && continue
    local pattern="${rest%% *}"
    local replacement=""
    if [[ "${rest}" != "${pattern}" ]]; then
      replacement="${rest#* }"
    fi
    [[ -z "${pattern}" ]] && continue
    FILTER_ACTIONS+=("${action}")
    FILTER_PATTERNS+=("${pattern}")
    FILTER_REPLACEMENTS+=("${replacement}")
  done < "${file}"
}

match_unsupported_pattern() {
  local arg="$1"
  local pat
  for pat in "${UNSUPPORTED_PATTERNS[@]}"; do
    if [[ "${arg}" == ${pat} ]]; then
      printf '%s' "${pat}"
      return 0
    fi
  done
  return 1
}

apply_wrapper_filter() {
  local args=("$@")
  local filtered=()
  local arg
  for arg in "${args[@]}"; do
    if [[ "${arg}" == "-dynamic" ]]; then
      echo "AFAR wrapper: ignored -dynamic (built-in)" >&2
      continue
    fi
    local unsupported=""
    unsupported="$(match_unsupported_pattern "${arg}" || true)"
    local action=""
    local replacement=""
    local i
    for i in "${!FILTER_ACTIONS[@]}"; do
      if [[ "${arg}" == ${FILTER_PATTERNS[$i]} ]]; then
        action="${FILTER_ACTIONS[$i]}"
        replacement="${FILTER_REPLACEMENTS[$i]}"
        break
      fi
    done

    if [[ -n "${unsupported}" ]]; then
      if [[ "${action}" == "ignore" ]]; then
        echo "AFAR wrapper: unsupported flag ignored via filter: ${arg} (pattern ${unsupported})" >&2
      elif [[ "${action}" == "replace" ]]; then
        echo "AFAR wrapper: unsupported flag replaced via filter: ${arg} -> ${replacement} (pattern ${unsupported})" >&2
      else
        echo "AFAR wrapper: unsupported flag: ${arg} (pattern ${unsupported}). Add to AFAR_WRAPPER_FILTER to ignore/replace." >&2
      fi
    fi

    if [[ "${action}" == "ignore" ]]; then
      continue
    elif [[ "${action}" == "replace" ]]; then
      if [[ -n "${replacement}" ]]; then
        read -r -a rep_args <<< "${replacement}"
        filtered+=("${rep_args[@]}")
      fi
    else
      filtered+=("${arg}")
    fi
  done

  set -- "${filtered[@]}"
  printf '%s\0' "$@"
}

mirror_fixed_pkgconfig() {
  local fixed="${PE_AMD_FIXED_PKGCONFIG_PATH:-}"
  local IFS=":"
  read -r -a items <<< "${fixed}"
  for ((idx=${#items[@]}-1; idx>=0; idx--)); do
    [[ -n "${items[idx]}" ]] || continue
    prepend_env_path PKG_CONFIG_PATH "${items[idx]}"
  done
}

select_mpich_flavor() {
  local ver="${CRAY_MPICH_VERSION:-}"
  local major="${ver%%.*}"
  if [[ -z "${major}" || ! "${major}" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  if (( major >= 9 )); then
    printf '%s\n' "mpich4.3.1"
  else
    printf '%s\n' "mpich3.4a2"
  fi
}

apply_mpich_pkgconfig_override() {
  local flavor=""
  flavor="$(select_mpich_flavor || true)"
  if [[ -z "${flavor}" || -z "${AFAR_VERSION:-}" ]]; then
    mirror_fixed_pkgconfig
    return 0
  fi
  local wrapper_dir
  wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local mpich_pc_dir="${wrapper_dir}/../pkgconfig/${AFAR_VERSION}/${flavor}"
  if [[ -f "${mpich_pc_dir}/mpichf90.pc" ]]; then
    prepend_env_path PE_AMD_FIXED_PKGCONFIG_PATH "${mpich_pc_dir}"
    export AFAR_MPICH_FLAVOR="${flavor}"
  fi
  mirror_fixed_pkgconfig
}

apply_mpich_pkgconfig_override

filter_file="${AFAR_WRAPPER_FILTER:-${wrapper_dir}/../config/wrapper-filter.txt}"
unsupported_file="${AFAR_WRAPPER_UNSUPPORTED:-${wrapper_dir}/../config/wrapper-unsupported-flags.txt}"
load_unsupported_patterns "${unsupported_file}"
load_filter_rules "${filter_file}"
if [[ -z "${AFAR_WRAPPER_FILTER_LOGGED:-}" ]]; then
  if [[ -f "${filter_file}" ]]; then
    echo "AFAR wrapper: loaded filter file ${filter_file}" >&2
  else
    echo "AFAR wrapper: filter file not found ${filter_file}" >&2
  fi
  if [[ -f "${unsupported_file}" ]]; then
    echo "AFAR wrapper: loaded unsupported flag file ${unsupported_file}" >&2
  else
    echo "AFAR wrapper: unsupported flag file not found ${unsupported_file}" >&2
  fi
  export AFAR_WRAPPER_FILTER_LOGGED=1
fi

mapfile -d '' -t filtered_args < <(apply_wrapper_filter "$@")
set -- "${filtered_args[@]}"

real_cxx="${AFAR_REAL_CXX:-}"
if [[ -z "${real_cxx}" ]]; then
  if [[ -n "${CRAYPE_DIR:-}" && -x "${CRAYPE_DIR}/bin/CC" ]]; then
    real_cxx="${CRAYPE_DIR}/bin/CC"
  fi
fi

if [[ -z "${real_cxx}" ]]; then
  wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  IFS=: read -r -a path_parts <<< "${PATH:-}"
  for p in "${path_parts[@]}"; do
    [[ -z "${p}" ]] && continue
    if [[ "${p}" == "${wrapper_dir}" ]]; then
      continue
    fi
    if [[ -x "${p}/CC" ]]; then
      real_cxx="${p}/CC"
      break
    fi
  done
fi

if [[ -z "${real_cxx}" ]]; then
  echo "AFAR CC wrapper: unable to locate real CC in PATH." >&2
  exit 127
fi

offload_arch="${AFAR_CXX_OFFLOAD_ARCH:-${AFAR_FTN_OFFLOAD_ARCH:-}}"
if [[ -n "${offload_arch}" ]]; then
  has_openmp=0
  has_offload_arch=0
  for arg in "$@"; do
    case "${arg}" in
      -fopenmp|-fopenmp=*|-openmp|-qopenmp|-mp)
        has_openmp=1
        ;;
      --offload-arch|--offload-arch=*)
        has_offload_arch=1
        ;;
    esac
  done

  if [[ "${has_openmp}" -eq 1 && "${has_offload_arch}" -eq 0 ]]; then
    set -- "$@" "--offload-arch=${offload_arch}"
  fi
fi

if [[ "${CRAYPE_LINK_TYPE:-}" == "dynamic" ]]; then
  unset CRAYPE_LINK_TYPE
fi

exec "${real_cxx}" "$@"
