#!/usr/bin/env bash
set -euo pipefail

wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

prepend_env_path() {
  local var="$1"
  local dir="$2"
  local val="${!var:-}"
  case ":${val}:" in
    *":${dir}:"*) return 0 ;;
  esac
  if [[ -n "${val}" ]]; then
    export "${var}=${dir}:${val}"
  else
    export "${var}=${dir}"
  fi
}

append_env_path() {
  local var="$1"
  local dir="$2"
  local val="${!var:-}"
  case ":${val}:" in
    *":${dir}:"*) return 0 ;;
  esac
  if [[ -n "${val}" ]]; then
    export "${var}=${val}:${dir}"
  else
    export "${var}=${dir}"
  fi
}

trim_line() {
  local line="$1"
  line="${line#"${line%%[![:space:]]*}"}"
  line="${line%"${line##*[![:space:]]}"}"
  printf '%s' "${line}"
}

FILTER_ACTIONS=()
FILTER_PATTERNS=()
FILTER_REPLACEMENTS=()

load_filter_rules() {
  local file="$1"
  [[ -f "${file}" ]] || return 0
  while IFS= read -r line || [[ -n "${line}" ]]; do
    line="${line%%#*}"
    line="$(trim_line "${line}")"
    [[ -z "${line}" ]] && continue
    local action="${line%% *}"
    local rest="${line#* }"
    [[ "${rest}" == "${line}" ]] && continue
    local pattern="${rest%% *}"
    local replacement=""
    if [[ "${rest}" != "${pattern}" ]]; then
      replacement="${rest#* }"
    fi
    [[ -z "${pattern}" ]] && continue
    FILTER_ACTIONS+=("${action}")
    FILTER_PATTERNS+=("${pattern}")
    FILTER_REPLACEMENTS+=("${replacement}")
  done < "${file}"
}

wrapper_warn() {
  if [[ "${AFAR_WRAPPER_QUIET:-}" == "1" ]]; then
    return 0
  fi
  echo "$@" >&2
}

apply_wrapper_filter() {
  local args=("$@")
  local filtered=()
  local arg
  for arg in "${args[@]}"; do
    local action=""
    local replacement=""
    local pattern=""
    local i
    for i in "${!FILTER_ACTIONS[@]}"; do
      if [[ "${arg}" == ${FILTER_PATTERNS[$i]} ]]; then
        action="${FILTER_ACTIONS[$i]}"
        replacement="${FILTER_REPLACEMENTS[$i]}"
        pattern="${FILTER_PATTERNS[$i]}"
        break
      fi
    done

    if [[ "${action}" == "ignore" ]]; then
      wrapper_warn "AFAR wrapper: ignored flag via filter: ${arg} (pattern ${pattern})"
      continue
    elif [[ "${action}" == "replace" ]]; then
      wrapper_warn "AFAR wrapper: replaced flag via filter: ${arg} -> ${replacement} (pattern ${pattern})"
      if [[ -n "${replacement}" ]]; then
        read -r -a rep_args <<< "${replacement}"
        filtered+=("${rep_args[@]}")
      fi
      continue
    fi

    filtered+=("${arg}")
  done

  set -- "${filtered[@]}"
  printf '%s\0' "$@"
}

mirror_fixed_pkgconfig() {
  local fixed="${PE_AMD_FIXED_PKGCONFIG_PATH:-}"
  local IFS=":"
  read -r -a items <<< "${fixed}"
  for ((idx=${#items[@]}-1; idx>=0; idx--)); do
    [[ -n "${items[idx]}" ]] || continue
    prepend_env_path PKG_CONFIG_PATH "${items[idx]}"
  done
}

select_mpich_flavor() {
  local ver="${CRAY_MPICH_VERSION:-}"
  local major="${ver%%.*}"
  if [[ -z "${major}" || ! "${major}" =~ ^[0-9]+$ ]]; then
    return 1
  fi
  if (( major >= 9 )); then
    printf '%s\n' "mpich4.3.1"
  else
    printf '%s\n' "mpich3.4a2"
  fi
}

apply_mpich_pkgconfig_override() {
  local flavor=""
  flavor="$(select_mpich_flavor || true)"
  if [[ -z "${flavor}" || -z "${AFAR_VERSION:-}" ]]; then
    mirror_fixed_pkgconfig
    return 0
  fi
  local wrapper_dir
  wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  local mpich_pc_dir="${wrapper_dir}/../pkgconfig/${AFAR_VERSION}/${flavor}"
  if [[ -f "${mpich_pc_dir}/mpichf90.pc" ]]; then
    prepend_env_path PE_AMD_FIXED_PKGCONFIG_PATH "${mpich_pc_dir}"
    export AFAR_MPICH_FLAVOR="${flavor}"
  fi
  mirror_fixed_pkgconfig
}

fix_libsci_acc_pkgconfig() {
  local libsci_acc_prefix="${CRAY_LIBSCI_ACC_PREFIX_DIR:-}"
  local pkg_libs="${PE_PKGCONFIG_LIBS:-}"
  local pkg_products="${PE_PKGCONFIG_PRODUCTS:-}"
  if [[ -z "${libsci_acc_prefix}" && "${pkg_libs}" != *"libsci_acc"* && "${pkg_products}" != *"PE_LIBSCI_ACC"* ]]; then
    return 0
  fi
  local vars="${PE_LIBSCI_ACC_PKGCONFIG_VARIABLES:-}"
  local target="${PE_LIBSCI_ACC_TARGET:-}"
  if [[ -z "${target}" ]]; then
    local offload="${AFAR_FTN_OFFLOAD_ARCH:-}"
    if [[ -n "${offload}" ]]; then
      target="${offload}"
      export PE_LIBSCI_ACC_TARGET="${offload}"
    fi
  fi
  if [[ -z "${vars}" || -z "${target}" ]]; then
    return 0
  fi
  local prgenv="${PE_LIBSCI_ACC_PRGENV:-}"
  if [[ -z "${prgenv}" ]]; then
    local pe_env="${PE_ENV:-}"
    if [[ -z "${pe_env}" ]]; then
      pe_env="amd"
    else
      pe_env="${pe_env,,}"
    fi
    prgenv="${pe_env}"
    export PE_LIBSCI_ACC_PRGENV="${prgenv}"
  fi
  local updated="${vars}"
  if [[ "${updated}" == *"@prgenv@"* && -n "${prgenv}" ]]; then
    updated="${updated//@prgenv@/${prgenv}}"
  fi
  if [[ "${updated}" == *"@accelerator@"* ]]; then
    local accel="${target}"
    if [[ "${target}" == gfx* ]]; then
      accel="amd_${target}"
    fi
    updated="${updated//@accelerator@/${accel}}"
  fi
  if [[ "${updated}" != "${vars}" ]]; then
    export PE_LIBSCI_ACC_PKGCONFIG_VARIABLES="${updated}"
  fi
}

apply_pkgconfig_shim_dir() {
  local shim="${AFAR_PKGCONFIG_SHIM_DIR:-}"
  [[ -n "${shim}" ]] || return 0
  append_env_path PKG_CONFIG_PATH "${shim}"
}

maybe_generate_pkgconfig_shims() {
  local auto="${AFAR_PKGCONFIG_SHIM_AUTO:-1}"
  if [[ "${auto}" == "0" ]]; then
    return 0
  fi
  local shim_script="${wrapper_dir}/../scripts/generate_pkgconfig_shims.sh"
  [[ -x "${shim_script}" ]] || return 0
  local key
  local key_parts=(
    "${AFAR_VERSION:-}"
    "${CRAY_MPICH_VERSION:-}"
    "${PE_PKGCONFIG_PRODUCTS:-}"
    "${PE_PKGCONFIG_LIBS:-}"
    "${PE_FORTRAN_PKGCONFIG_LIBS:-}"
    "${PE_CXX_PKGCONFIG_LIBS:-}"
    "${CRAY_HDF5_DIR:-}"
    "${CRAY_HDF5_PARALLEL_DIR:-}"
    "${CRAY_HDF5_PREFIX:-}"
    "${CRAY_HDF5_PARALLEL_PREFIX:-}"
    "${CRAY_FFTW_PREFIX:-}"
    "${FFTW_ROOT:-}"
    "${CRAY_DSMML_PREFIX:-}"
    "${CRAY_DSMML_DIR:-}"
    "${CRAY_PARALLEL_NETCDF_PREFIX:-}"
    "${CRAY_PARALLEL_NETCDF_DIR:-}"
    "${PNETCDF_DIR:-}"
    "${CRAY_LIBSCI_PREFIX_DIR:-}"
    "${CRAY_LIBSCI_ACC_PREFIX_DIR:-}"
    "${PE_LIBSCI_PKGCONFIG_VARIABLES:-}"
    "${PE_LIBSCI_ACC_PKGCONFIG_VARIABLES:-}"
    "${PE_HDF5_PKGCONFIG_LIBS:-}"
    "${PE_HDF5_PARALLEL_PKGCONFIG_LIBS:-}"
    "${PE_PARALLEL_NETCDF_PKGCONFIG_LIBS:-}"
    "${PE_DSMML_PKGCONFIG_LIBS:-}"
    "${PE_FFTW_PKGCONFIG_LIBS:-}"
    "${AFAR_PKGCONFIG_SHIM_DIR:-}"
  )
  local IFS='|'
  key="${key_parts[*]}"
  if [[ "${key}" == "${AFAR_PKGCONFIG_SHIM_KEY:-}" ]]; then
    return 0
  fi
  local shim_dir
  shim_dir="$("${shim_script}")" || return 0
  [[ -n "${shim_dir}" ]] || return 0
  export AFAR_PKGCONFIG_SHIM_DIR="${shim_dir}"
  export AFAR_PKGCONFIG_SHIM_KEY="${key}"
}

apply_mpich_pkgconfig_override
fix_libsci_acc_pkgconfig
maybe_generate_pkgconfig_shims
apply_pkgconfig_shim_dir

filter_file="${AFAR_WRAPPER_FILTER:-${wrapper_dir}/../config/wrapper-filter.txt}"
extra_filter="${AFAR_WRAPPER_FILTER_EXTRA:-${AFAR_WRAPPER_FILTER_LOCAL:-}}"
load_filter_rules "${filter_file}"
if [[ -n "${extra_filter}" ]]; then
  load_filter_rules "${extra_filter}"
fi
if [[ "${AFAR_WRAPPER_DEBUG:-}" == "1" ]]; then
  if [[ -f "${filter_file}" ]]; then
    echo "AFAR wrapper debug: filter file ${filter_file}" >&2
  else
    echo "AFAR wrapper debug: filter file not found ${filter_file}" >&2
  fi
  if [[ -n "${extra_filter}" ]]; then
    if [[ -f "${extra_filter}" ]]; then
      echo "AFAR wrapper debug: extra filter file ${extra_filter}" >&2
    else
      echo "AFAR wrapper debug: extra filter file not found ${extra_filter}" >&2
    fi
  fi
fi

mapfile -d '' -t filtered_args < <(apply_wrapper_filter "$@")
set -- "${filtered_args[@]}"

real_cc="${AFAR_REAL_CC:-}"
if [[ -z "${real_cc}" ]]; then
  if [[ -n "${CRAYPE_DIR:-}" && -x "${CRAYPE_DIR}/bin/cc" ]]; then
    real_cc="${CRAYPE_DIR}/bin/cc"
  fi
fi

if [[ -z "${real_cc}" ]]; then
  wrapper_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
  IFS=: read -r -a path_parts <<< "${PATH:-}"
  for p in "${path_parts[@]}"; do
    [[ -z "${p}" ]] && continue
    if [[ "${p}" == "${wrapper_dir}" ]]; then
      continue
    fi
    if [[ -x "${p}/cc" ]]; then
      real_cc="${p}/cc"
      break
    fi
  done
fi

if [[ -z "${real_cc}" ]]; then
  echo "AFAR cc wrapper: unable to locate real cc in PATH." >&2
  exit 127
fi

offload_arch="${AFAR_CC_OFFLOAD_ARCH:-${AFAR_FTN_OFFLOAD_ARCH:-}}"
if [[ -n "${offload_arch}" ]]; then
  has_openmp=0
  has_offload_arch=0
  for arg in "$@"; do
    case "${arg}" in
      -fopenmp|-fopenmp=*|-openmp|-qopenmp|-mp)
        has_openmp=1
        ;;
      --offload-arch|--offload-arch=*)
        has_offload_arch=1
        ;;
    esac
  done

  if [[ "${has_openmp}" -eq 1 && "${has_offload_arch}" -eq 0 ]]; then
    set -- "$@" "--offload-arch=${offload_arch}"
  fi
fi


if [[ "${CRAYPE_LINK_TYPE:-}" == "dynamic" ]]; then
  unset CRAYPE_LINK_TYPE
fi

exec "${real_cc}" "$@"
